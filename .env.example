# 用户管理系统 v1.0-backend 环境配置（示例）
# @author 樊高工
# 复制此文件为 .env 并修改配置值

# 服务配置
NODE_ENV=production
PORT=3000

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=user_management_system

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME

# JWT 配置（生产环境务必修改）
JWT_SECRET=CHANGE_ME_TO_A_STRONG_SECRET